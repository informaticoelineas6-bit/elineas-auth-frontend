# .env.production.example
# Copiar a .env.production antes de levantar docker-compose.prod.yml
# (ese archivo lo carga vía `env_file`, no forma parte de la imagen).

# URL base del identity server (elineas-auth) en producción.
AUTH_API_URL=

# Slug del "sistema" que representa a este frontend en elineas-auth. Debe
# existir previamente en el IS (lo crea un admin vía POST /api/systems) y el
# usuario que inicia sesión debe tener al menos un rol asignado en él; si no,
# el sign-in responde 403 "El usuario no tiene ningún rol en el sistema".
AUTH_SYSTEM_SLUG=
