# .env.example
# URL base del identity server (elineas-auth).
AUTH_API_URL=http://localhost:8080

# Slug del "sistema" que representa a este frontend en elineas-auth. Debe
# existir previamente en el IS (lo crea un admin vía POST /api/systems) y el
# usuario que inicia sesión debe tener al menos un rol asignado en él; si no,
# el sign-in responde 403 "El usuario no tiene ningún rol en el sistema".
AUTH_SYSTEM_SLUG=

# Captcha invisible del login (Cloudflare Turnstile). Opcionales: sin
# configurar, el login funciona sin captcha (útil en desarrollo). Crea un
# sitio en https://dash.cloudflare.com/?to=/:account/turnstile y pega aquí
# la site key (pública) y el secret key (nunca la expongas al cliente).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
